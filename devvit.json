{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "wobbletower",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "WOBBLE: create tower post",
        "description": "Create the shared tower post for this subreddit",
        "forUserType": "moderator",
        "location": [
          "subreddit"
        ],
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "dev": {
    "subreddit": "wobbletower_dev"
  }
}